# Copy to .env on VPS: cp .env.example .env  (and fill in values)

# App
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
APP_URL=https://v2.nexus-x.site

# Database (existing nexus_db Postgres container, new nexus_v2 database)
# Hostname `nexus_db` because both containers share deployment_nexus_network
DATABASE_URL=postgres://nexus_v2:CHANGE_ME_STRONG_PASSWORD@nexus_db:5432/nexus_v2

# Auth — generate with: openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-string-32-bytes-hex-minimum
SESSION_SECRET=change-this-too-another-long-random-string

# STEX upstream SMS provider
STEX_API_BASE=https://api.2oo9.cloud/MXS47FLFX0U/tness/@public/api
STEX_API_KEY=
# Default payout per successful OTP in USD (admin per-range pricing TBD)
STEX_DEFAULT_PAYOUT=0.10

# Global poller tuning (single shared loop replaces per-connection STEX polls)
STEX_POLL_INTERVAL_MS=4000
# Minimum gap between any two STEX API calls (throttle / quota protection)
STEX_MIN_GAP_MS=200
