# Copy to .env on VPS: cp .env.example .env  (tarpor value gulo fill koro)

# App
NODE_ENV=production
PORT=3000
HOST=0.0.0.0
APP_URL=https://v2.nexus-x.site

# Database (nexus_db existing Postgres container e notun DB)
DATABASE_URL=postgres://nexus_v2:CHANGE_ME_STRONG_PASSWORD@nexus_db:5432/nexus_v2

# Auth / sessions
SESSION_SECRET=change-this-to-a-long-random-string-64-chars-minimum
JWT_SECRET=change-this-too-another-long-random-string

# (Future) SMS / OTP integration secrets
# SMS_FORWARDER_API_KEY=
